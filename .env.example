# Copy to .env and fill in. On the VPS this file lives at
# /opt/upwork-scanner/.env (chmod 600) and is never committed to git.

# ============================================================
# ENVIRONMENT
# ============================================================
# production = cron scheduling + Slack/email notifications
# dev        = file output in output/ + immediate one-off scan
# NOTE: docker-compose.yml forces NODE_ENV=production for the container.
NODE_ENV=production

# Internal port the app listens on (docker-compose forces 3000; not published).
PORT=3000

# ============================================================
# UPWORK SEARCH
# ============================================================
# Your saved Upwork search URL (sorted by recency).
UPWORK_RSS_URL=https://www.upwork.com/nx/search/jobs/?q=%28react+OR+next.js+OR+node.js+OR+express+OR+javascript%29&sort=recency

# ============================================================
# CLOUDFLARE BYPASS
# ============================================================
# "flaresolverr" - FREE, runs as the `flaresolverr` service in docker-compose.
# "scraperapi"   - Paid; set SCRAPER_API_KEY below instead.
# "direct"       - No bypass (testing only).
FETCH_METHOD=flaresolverr
# Points at the flaresolverr service on the compose network (docker-compose
# also sets this — leave as-is for VPS, use http://localhost:8191 for local).
FLARESOLVERR_URL=http://flaresolverr:8191
SCRAPER_API_KEY=

# ============================================================
# NOTIFICATIONS
# ============================================================
# Primary channel — this is the one that must work.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email (optional fallback; leave blank to disable).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ============================================================
# TIMING
# ============================================================
# Scans every 10 min for jobs < 15 min old, 24/7.
MAX_JOB_AGE_MINUTES=15
CRON_SCHEDULE=*/10 * * * *

# ============================================================
# SCORING / THRESHOLDS  (favor fewer-but-better matches)
# ============================================================
MIN_BUDGET=500
MIN_HIRE_RATE=50
MIN_PAST_HIRES=1
MIN_SCORE=7
# Reject hourly jobs whose top rate is below this ($/hr).
MIN_HOURLY_RATE=15
HIGH_BUDGET_THRESHOLD=1000
HIGH_CLIENT_SPEND=1500

# ============================================================
# LEAD LOGGING + DAILY REVIEW  (heuristic, $0, no external deps)
# ============================================================
# Logs every unique job (sent + rejected) to data/logs/*.jsonl and writes a
# daily markdown report to data/reports/ for review with /daily-review.
LOG_LEADS=true
LOG_RETENTION_DAYS=30
# A below-threshold job within this many points of MIN_SCORE is a "near-miss"
# (top candidate for a good lead we wrongly dropped).
NEAR_MISS_WINDOW=4
# Chars of each job description kept in the log (for review).
LOG_DESC_LENGTH=1000
# Don't re-log the same job link within this many hours (dedup across scans).
LOG_DEDUP_HOURS=36
# When the daily report runs. The container TZ is Africa/Cairo (set in
# docker-compose.yml), so "0 8 * * *" = 8 AM Cairo. No UTC math needed.
REPORT_CRON_SCHEDULE=0 8 * * *
POST_REPORT_TO_SLACK=true
