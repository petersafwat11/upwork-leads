# Environment (dev = file output + immediate scan, production = cron + slack/email)
NODE_ENV=production

# Server
PORT=3000

# Upwork Search URL (your saved search)
UPWORK_RSS_URL=https://www.upwork.com/nx/search/jobs/?q=%28react+OR+next.js+OR+node.js+OR+express+OR+javascript+OR+fullstack+OR+full+stack+OR+tailwind+OR+postgresql%29&sort=recency

# ============================================================
# CLOUDFLARE BYPASS
# ============================================================
# "flaresolverr" - FREE, open-source (recommended)
#   Deploy as separate service on Railway, or run locally:
#   docker run -d -p 8191:8191 ghcr.io/flaresolverr/flaresolverr
#
# "scraperapi" - Paid ($29/mo), no extra service needed
# "browser"    - Built-in Puppeteer stealth (unreliable with Cloudflare)
# "direct"     - No bypass (testing only)
FETCH_METHOD=flaresolverr
FLARESOLVERR_URL=http://flaresolverr.railway.internal:8191

# Only if using scraperapi:
SCRAPER_API_KEY=

# ============================================================
# NOTIFICATIONS
# ============================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email (optional fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ============================================================
# TIMING
# ============================================================
# Scans every 10 min, only jobs < 15 min old
# Operating hours: 12 PM - 12 AM UTC (hardcoded, no scans midnight-noon)
MAX_JOB_AGE_MINUTES=15
CRON_SCHEDULE=*/10 * * * *

# ============================================================
# SCORING
# ============================================================
MIN_BUDGET=500
MIN_SCORE=8
HIGH_BUDGET_THRESHOLD=1000
HIGH_CLIENT_SPEND=1500
